# ============================================
# MedTrainer - Environment Variables
# ============================================

# Google Gemini API Key (OBRIGATÓRIO)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua_chave_google_gemini_aqui

# N8N Webhooks (OPCIONAL)
# Para registro de logs e análise de interações
N8N_WEBHOOK_LOG=
N8N_WEBHOOK_BUSCAR=

# Configurações da API (OPCIONAL)
# API_HOST=0.0.0.0
# API_PORT=8000

# Configurações do MCP Server (OPCIONAL)
# MCP_PORT=8001

# Configurações de Debug (OPCIONAL)
# DEBUG=False
# LOG_LEVEL=INFO
